@model IEnumerable<SocialMediaPost>

@{
    ViewBag.Title = "SocialSpace";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h1 class="h2 fw-bold mb-1">Social Space</h1>
                    <p class="text-muted mb-0">Share updates and see what others are posting.</p>
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="rounded-circle bg-secondary-subtle d-flex align-items-center justify-content-center me-3"
                             style="width: 48px; height: 48px;">
                            <span class="fw-bold text-dark">
                                @((User?.Identity?.Name?.FirstOrDefault().ToString().ToUpper()) ?? "U")
                            </span>
                        </div>
                        <div>
                            <h2 class="h5 mb-0">Create Post</h2>
                            <small class="text-muted">Share something with your community</small>
                        </div>
                    </div>

                    <form id="postForm" method="post" asp-controller="Social" asp-action="CreatePost">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label for="PostContent" class="form-label fw-semibold">What's on your mind?</label>
                            <textarea class="form-control rounded-3"
                                      id="PostContent"
                                      name="PostContent"
                                      rows="4"
                                      placeholder="Write your post here..."
                                      required></textarea>
                        </div>

                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-primary px-4 rounded-3">
                                Post
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="d-flex align-items-center justify-content-between mb-3">
                <h3 class="h5 fw-semibold mb-0">Recent Posts</h3>
                <span class="badge rounded-pill text-bg-secondary">
                    @(Model?.Count() ?? 0) post(s)
                </span>
            </div>

            @if (Model == null || !Model.Any())
            {
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body p-5 text-center">
                        <div class="mb-3 fs-1">📝</div>
                        <h4 class="fw-semibold">No posts yet</h4>
                        <p class="text-muted mb-0">Be the first to share something.</p>
                    </div>
                </div>
            }
            else
            {
                @foreach (SocialMediaPost post in Model)
                {
                    <div id="@post.PostId" class="card shadow-sm border-0 rounded-4 mb-3">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle bg-secondary-subtle d-flex align-items-center justify-content-center me-3"
                                         style="width: 44px; height: 44px;">
                                        <span class="fw-bold text-dark">
                                            @((post.PostAuthor?.FirstOrDefault().ToString().ToUpper()) ?? "U")
                                        </span>
                                    </div>
                                    <div>
                                        <div class="fw-semibold">@post.PostAuthor</div>
                                        <small class="text-muted">
                                            @(post.PostDate == default
                                                ? "Just now"
                                                : post.PostDate.ToString("dd MMM yyyy • HH:mm"))
                                        </small>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <p class="mb-0 fs-6" style="white-space: pre-wrap;">@post.PostContent</p>
                            </div>

                            <div class="d-flex align-items-center gap-2 pt-2 border-top">
                                <button type="button" class="btn btn-sm btn-outline-secondary rounded-3" disabled>
                                    Like
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-secondary rounded-3" disabled>
                                    Comment
                                </button>
                                <div class="ms-auto text-muted small">
                                    ID: @post.PostId
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }

        </div>
    </div>
</div>